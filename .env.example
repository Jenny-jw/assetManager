# Copy to .env at repo root for docker compose, or to backend/.env for local uvicorn.
# Never commit real secrets.

# MongoDB connection string
# Docker Compose (service name "mongo"): mongodb://mongo:27017
# Local Mongo on host: mongodb://localhost:27017
# MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority
MONGO_URI=mongodb://mongo:27017

# JWT signing secret — use a long random string in production
JWT_SECRET_KEY=change-me-in-production

# Mongo multi-doc transactions need a replica set (Atlas or compose replica set).
# Standalone local/mongo:7 container — keep false.
USE_DB_TRANSACTIONS=false

# Set false when API is served over plain HTTP (local dev, Docker without TLS)
JWT_COOKIE_SECURE=false